# Application Settings
APP_NAME="AI Social Media Agent"
APP_ENV="development"
DEBUG=True

# LLM Configuration
LLM_PROVIDER="groq"
MODEL_NAME="groq/llama-3.3-70b-versatile"

# API Keys (Placeholders)
GROQ_API_KEY="your_groq_api_key_here"
OPENAI_API_KEY="your_openai_api_key_here"
GEMINI_API_KEY="your_gemini_api_key_here"
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# LinkedIn API Credentials (Placeholders)
LINKEDIN_CLIENT_ID="your_linkedin_client_id_here"
LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret_here"
LINKEDIN_ACCESS_TOKEN="your_linkedin_access_token_here"

# Instagram Graph API Credentials (Placeholders)
# Obtain from https://developers.facebook.com/ → your Facebook App → Instagram product
IG_ACCESS_TOKEN="your_instagram_access_token_here"
IG_BUSINESS_ACCOUNT_ID="your_instagram_business_account_id_here"
